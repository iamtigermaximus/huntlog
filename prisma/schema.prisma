generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  resumes      Resume[]
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Job Details
  jobTitle        String
  company         String
  location        String?
  jobDescription  String   @db.Text
  jobUrl          String?
  salaryMin       Int?
  salaryMax       Int?
  jobType         String?
  seniorityLevel  String?
  
  // Dates
  appliedDate        DateTime @default(now())
  jobPostingDate     DateTime?
  jobExpirationDate  DateTime?
  offerDeadline      DateTime?
  followUpDate       DateTime?
  lastUpdated        DateTime @updatedAt
  
  // Status & AI Analysis
  status          Status   @default(WISHLIST)
  matchScore      Int?
  missingSkills   String?  @db.Text
  recommendations String?  @db.Text
  strengths       String?  @db.Text
  notes           String?  @db.Text
  coverLetter     String?  @db.Text
  
  // Resume
  resumeId        String?
  resume          Resume?  @relation(fields: [resumeId], references: [id])
  
  // Receipt Confirmation
  confirmationReceived  Boolean  @default(false)
  confirmationDate      DateTime?
  confirmationNotes     String?  @db.Text
  
  // Source
  source          String?
  referralName    String?
  
  // Interviews
  interviews Interview[]
  
  @@index([userId])
  @@index([status])
  @@index([appliedDate])
  @@index([jobExpirationDate])
  @@index([confirmationReceived])
}

model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  fileName  String
  content   String?  @db.Text
  fileUrl   String?
  isActive  Boolean  @default(false)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  lastUsed  DateTime?
  
  applications Application[]
  
  @@index([userId])
}

model Interview {
  id             String   @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  round          String
  scheduledDate  DateTime
  duration       Int?
  location       String?
  interviewerName String?
  interviewerEmail String?
  notes          String?  @db.Text
  feedback       String?  @db.Text
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  
  @@index([scheduledDate])
}

enum Status {
  WISHLIST
  APPLIED
  REVIEWING
  PHONE_SCREEN
  TECHNICAL
  ONSITE
  OFFER
  NEGOTIATING
  ACCEPTED
  REJECTED
  GHOSTED
  ARCHIVED
}